# ── Ethereum / Sepolia ────────────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
PRIVATE_KEY=0xYOUR_OPERATOR_WALLET_PRIVATE_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
# Optional EIP-712 chain-id override. If empty, runtime uses provider chainId.
CHAIN_ID=11155111

# Public submission assets (Phase 2)
# If these are left blank or placeholder values, the manifest generator falls back to repository-hosted public docs.
SUBMISSION_GITHUB_URL=
DEMO_URL=
DEMO_VIDEO_URL=
DEMO_SLIDES_URL=
# Strict submission mode turns mixed-agent artifacts and missing reputation into hard failures.
SUBMISSION_STRICT=false
PHASE2_MAX_ARTIFACT_AGE_MINUTES=1440

# ── Agent wallets ─────────────────────────────────────────────────────────────
# operatorWallet owns the ERC-721 token (can be cold wallet).
# agentWallet is the hot wallet the agent uses for signing TradeIntents + checkpoints.
# If not set, AGENT_WALLET_PRIVATE_KEY falls back to PRIVATE_KEY.
AGENT_WALLET_PRIVATE_KEY=0xYOUR_AGENT_HOT_WALLET_PRIVATE_KEY
# Optional signer override for contract-wallet paths (ERC-1271 owner/delegate signer).
AGENT_SIGNER_PRIVATE_KEY=
# Optional smart contract wallet address registered as agentWallet.
AGENT_WALLET_ADDRESS=

# ── Execution adapter ─────────────────────────────────────────────────────────
# mock   = synthetic market + mock fills (no Kraken key required)
# kraken = use Kraken CLI adapter
EXECUTION_MODE=mock

# Mock market settings (used when EXECUTION_MODE=mock)
MOCK_BASE_PRICE=65000
MOCK_BASE_VOLUME=1200
MOCK_VOLATILITY_BPS=30
MOCK_TREND_BPS=0
MOCK_SPREAD_BPS=2

# ── Kraken API ────────────────────────────────────────────────────────────────
# Optional unless EXECUTION_MODE=kraken
# Install the Kraken CLI: https://github.com/kraken-oss/kraken-cli
KRAKEN_API_KEY=YOUR_KRAKEN_API_KEY
KRAKEN_API_SECRET=YOUR_KRAKEN_API_SECRET
KRAKEN_SANDBOX=true                         # true = paper trading, false = live
KRAKEN_CLI_PATH=kraken                      # path to CLI binary if not on PATH
KRAKEN_CLI_ARGS=                            # optional launcher args (WSL example: -d Ubuntu -- env PATH=/home/<user>/.cargo/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin kraken)

# ── Strykr PRISM market data ─────────────────────────────────────────────────
# Optional unless MARKET_DATA_MODE=prism
PRISM_API_KEY=
PRISM_API_BASE_URL=https://api.prismapi.ai
PRISM_TIMEOUT_MS=12000
PRISM_SYNTHETIC_SPREAD_BPS=1                # synthetic spread used when Prism returns midpoint-only prices
PRISM_CACHE_TTL_MS=60000                    # local cache TTL for Prism market endpoints
PRISM_MAX_REQUESTS_PER_MINUTE=12            # local safety budget for live Prism requests
PRISM_RATE_LIMIT_COOLDOWN_MS=900000         # fallback cooldown when Prism returns rate-limit responses
PRISM_FALLBACK_TO_KRAKEN=true               # fallback to Kraken public ticker if Prism request fails

# ── Shared Hackathon Sepolia contracts ────────────────────────────────────────
AGENT_REGISTRY_ADDRESS=0x97b07dDc405B0c28B17559aFFE63BdB3632d0ca3
HACKATHON_VAULT_ADDRESS=0x0E7CD8ef9743FEcf94f9103033a044caBD45fC90
RISK_ROUTER_ADDRESS=0xd6A6952545FF6E6E6681c2d15C59f9EB8F40FdBC
REPUTATION_REGISTRY_ADDRESS=0x423a9904e39537a9997fbaF0f220d79D7d545763
VALIDATION_REGISTRY_ADDRESS=0x92bF63E5C7Ac6980f237a7164Ab413BE226187F1

# ── Agent identity ────────────────────────────────────────────────────────────
# Final submission uses shared Sepolia agent 5. Leave blank for dev-only flows.
AGENT_ID=

# ── Sandbox capital allocation ───────────────────────────────────────────────
# Used by scripts/allocate-sandbox-capital.ts (ETH amount per allocation call)
SANDBOX_CAPITAL_ETH=0.05

# ── Agent config ──────────────────────────────────────────────────────────────
TRADING_PAIR=XBTUSD
POLL_INTERVAL_MS=60000
MARKET_DATA_MODE=mock                       # mock = synthetic feed, kraken/prism = live market feed
TRADING_STRATEGY=llm                        # llm = planner-executor, indicator = deterministic technical signals, momentum = basic fallback
LLM_PROVIDER=groq                           # groq = Groq planner, openrouter = OpenRouter planner
CHECKPOINTS_FILE=checkpoints.jsonl
FILLS_FILE=fills.jsonl
PLANNER_RECENT_LIMIT=6
PLANNER_MAX_TRADE_USD=100
PLANNER_MAX_TRADES_PER_HOUR=6
PLANNER_MAX_SLIPPAGE_BPS=50
PLANNER_MIN_CONFIDENCE=0.62
PLANNER_MIN_EXPECTED_EDGE_BPS=12
PLANNER_ASSUMED_FEE_BPS=6
PLANNER_ASSUMED_SLIPPAGE_BPS=12

# Dual-gate execution policy (deterministic indicator signal + planner agreement)
DUAL_GATE_ENABLED=true
DUAL_GATE_MIN_NET_EDGE_BPS=8
DUAL_GATE_PROBE_USD=30
DUAL_GATE_PROBE_MIN_CONFIDENCE=0.66

# CPPI-style dynamic risk budget
CPPI_FLOOR_RATIO=0.95
CPPI_MULTIPLIER=1.0
CPPI_MIN_SCALE_TO_TRADE=0.10

# Circuit-breaker controls
CIRCUIT_BREAKER_ENABLED=true
BREAKER_MAX_CONSECUTIVE_LOSSES=3
BREAKER_MAX_DAILY_LOSS_USD=200
BREAKER_PAUSE_MS=300000
BREAKER_VOLATILITY_THROTTLE_PCT=2.8
BREAKER_VOLATILITY_SIZE_MULTIPLIER=0.6

# Indicator strategy tuning (used when TRADING_STRATEGY=indicator)
INDICATOR_LOOKBACK=90
INDICATOR_TRADE_AMOUNT_USD=100
INDICATOR_MIN_SIGNAL_SCORE=0.4
INDICATOR_MIN_CONFIDENCE=0.5
INDICATOR_MIN_NET_EDGE_BPS=3
INDICATOR_MAX_SPREAD_BPS=3
INDICATOR_MIN_TREND_BPS=0.5
INDICATOR_MIN_TRADE_INTERVAL_MS=120000

# One-shot readiness gates (enabled by default in phase2-evidence/evaluate)
PHASE2_ENFORCE_ONE_SHOT_GATES=true
PHASE2_MIN_CHECKPOINTS=30
PHASE2_MAX_CHECKPOINTS=60
PHASE2_MIN_FILLS=5
PHASE2_MAX_FILLS=15
PHASE2_MIN_NET_PNL_USD=0.01
PHASE2_MAX_DRAWDOWN_BPS=500
PHASE2_MIN_VALIDATION_COVERAGE_PCT=70
PHASE2_REQUIRE_VALIDATION_REGISTRY=true
PHASE2_MIN_REPUTATION_FEEDBACK_COUNT=3
PHASE2_MIN_REPUTATION_DISTINCT_RATERS=1
PHASE2_REQUIRE_REPUTATION_REGISTRY=true



# Final demo profile
# AGENT_ID=5
# EXECUTION_MODE=kraken
# KRAKEN_SANDBOX=true
# MARKET_DATA_MODE=prism
# TRADING_STRATEGY=llm
# LLM_PROVIDER=groq
# PLANNER_MAX_TRADE_USD=50
# PLANNER_MAX_TRADES_PER_HOUR=6
# PLANNER_MAX_SLIPPAGE_BPS=50
# PLANNER_MIN_CONFIDENCE=0.62

# ── Groq planner ──────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL_PRIMARY=openai/gpt-oss-20b
GROQ_MODEL_SECONDARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant

# ── OpenRouter planner ───────────────────────────────────────────────────────
OPENROUTER_API_KEY_A=
OPENROUTER_API_KEY_B=
OPENROUTER_MODEL_PRIMARY=arcee-ai/trinity-mini:free
OPENROUTER_MODEL_SECONDARY=stepfun/step-3.5-flash:free
OPENROUTER_MODEL_FALLBACK=openrouter/free
OPENROUTER_APP_TITLE=GLM Trading Agent
OPENROUTER_APP_URL=
OPENROUTER_CATEGORIES=trading,agentic,paper-trading


